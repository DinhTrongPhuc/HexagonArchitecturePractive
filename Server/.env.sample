# Server Configuration
PORT=5000

# Repository Type: MONGODB | JSON | MEMORY
REPO_TYPE=JSON

# MongoDB Configuration (Only if REPO_TYPE=MONGODB)
MONGODB_URI=mongodb://localhost:27017/note_app

# AI Configuration
# AI_TYPE: GROQ | GEMINI
AI_TYPE=GROQ
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Automation & External Tools
CRM_TOKEN=your_crm_token_here

# Outlook Email Scanning Configuration
OUTLOOK_TENANT_ID=your_tenant_id
OUTLOOK_CLIENT_ID=your_client_id
OUTLOOK_SEARCH_PHRASE="xem phiếu hỗ trợ, view ticket"
OUTLOOK_SEARCH_LIMIT=10
OUTLOOK_SCAN_INTERVAL=300000 # 5 minutes in milliseconds
OUTLOOK_TARGET_MAILBOX=your_target_email@domain.com